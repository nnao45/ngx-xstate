{
  "name": "@zstate/core",
  "version": "0.1.0",
  "description": "Framework-agnostic XState v5 + Zod type machinery: typedSetup, matchActor, renderStateTree, runtime validation",
  "keywords": ["xstate", "state-machine", "zod", "typescript", "type-safe"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.spec.json --noEmit"
  },
  "peerDependencies": {
    "xstate": ">=5.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  }
}
