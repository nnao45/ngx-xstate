{
  "name": "@zstate/ngx",
  "version": "0.1.0",
  "description": "Angular bindings for XState v5 with Zod, built on Signals (zoneless). The Angular equivalent of @xstate/react.",
  "keywords": ["angular", "xstate", "state-machine", "signals", "zod", "zoneless"],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist"
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.spec.json --noEmit"
  },
  "dependencies": {
    "@zstate/core": "workspace:^"
  },
  "peerDependencies": {
    "@angular/core": ">=20.0.0",
    "xstate": ">=5.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^20.3.23",
    "@angular/compiler-cli": "^20.3.23",
    "@angular/core": "^20.3.23",
    "@angular/platform-browser": "^20.3.23",
    "@angular/platform-browser-dynamic": "^20.3.23",
    "jsdom": "^25.0.0",
    "ng-packagr": "^20.3.2"
  }
}
