{
  "name": "zstate",
  "version": "0.0.0",
  "private": true,
  "description": "XState v5 + Zod: framework-agnostic core (@zstate/core) and Angular bindings (@zstate/ngx)",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint --type-aware --deny-warnings packages",
    "format": "oxfmt --write 'packages/**/*.ts' 'packages/**/*.tsx'",
    "format:check": "oxfmt --check 'packages/**/*.ts' 'packages/**/*.tsx'",
    "check": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^3.2.4",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0",
    "xstate": "^5.32.0",
    "zod": "^3.24.0"
  },
  "packageManager": "pnpm@11.5.0"
}
