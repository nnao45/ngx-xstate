{
  "name": "ngx-xstate",
  "version": "0.1.0",
  "description": "Angular bindings for XState v5 with Zod schema integration",
  "keywords": [
    "angular",
    "xstate",
    "state-machine",
    "signals",
    "zod"
  ],
  "license": "MIT",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.lib.json --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@angular/core": ">=20.0.0",
    "xstate": ">=5.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@angular/compiler": "^20.3.23",
    "@angular/compiler-cli": "^20.3.23",
    "@angular/core": "^20.3.23",
    "@angular/platform-browser": "^20.3.23",
    "@angular/platform-browser-dynamic": "^20.3.23",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^25.0.0",
    "ng-packagr": "^20.3.2",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.0",
    "xstate": "^5.32.0",
    "zod": "^3.24.0"
  }
}
